@using TimeCalculator.AiCore
@using TimeCalculator.Core
@using TimeCalculator.Core.Types
@using AIOrchestrator.Core.Types

<div class="d-flex flex-column flex-lg-row gap-4 align-items-start">
    <!-- Main Form Controls -->
    <div class="d-flex flex-column gap-4" style="width: 100%; max-width: 400px;">
        <!-- Time Inputs -->
        <div class="d-flex gap-2 align-items-end">
            <div class="d-flex flex-column">
                <label class="form-label mb-1">Hours</label>
                <input type="number" @bind="TimeCalculator.CurrentTimeEntry.Time.Hours" min="0" class="form-control"
                       style="width: 80px;"/>
            </div>

            <div class="d-flex flex-column">
                <label class="form-label mb-1">Minutes</label>
                <input type="number" @bind="TimeCalculator.CurrentTimeEntry.Time.Minutes" min="0" max="59"
                       class="form-control" style="width: 80px;"/>
            </div>

            <div class="d-flex flex-column">
                <label class="form-label mb-1">Seconds</label>
                <input type="number" @bind="TimeCalculator.CurrentTimeEntry.Time.Seconds" min="0" max="59"
                       class="form-control" style="width: 80px;"/>
            </div>

            <div class="ms-auto">
                <div class="btn-group" role="group" aria-label="Time entry type">
                    <button type="button" class="@GetTypeButtonClass(TimeType.Work)"
                            aria-pressed="@(IsTypeSelected(TimeType.Work))" @onclick="() => TimeCalculator.SetType(TimeType.Work)">
                        Work
                    </button>
                    <button type="button" class="@GetTypeButtonClass(TimeType.Break)"
                            aria-pressed="@(IsTypeSelected(TimeType.Break))"
                            @onclick="() => TimeCalculator.SetType(TimeType.Break)">
                        Break
                    </button>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="AddTimeEntry">Add Entry</button>
            <button class="btn btn-outline-primary" @onclick="SetRemainedTime">Remained</button>
        </div>

        <hr class="my-0 opacity-10"/>

        <!-- AI Assistant Group (Explain + Type nearby) -->
        <div class="d-flex flex-column gap-2">
            <label class="form-label mb-1">Explain it - we'll try to do it!</label>
            <textarea @bind="AiInteraction.UserInput"
                   class="form-control" style="height: 120px;" placeholder="e.g., 'add 2 hours of work'"></textarea>
            <button class="btn btn-primary w-100" @onclick="AiInteraction.AskAsync">Do it!</button>
        </div>
    </div>

    <!-- AI Debug Details Sidebar -->
    <div class="d-flex flex-column flex-grow-1" style="max-width: 500px;">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="form-label mb-0">AI Debug Details</label>
            <button class="btn btn-outline-primary btn-sm"
                    onclick="window.copyToClipboard('ai-debug-out', this)">
                Copy
            </button>
        </div>
        <div class="form-control" style="height: 385px; overflow-y: auto; display: flex; flex-direction: column-reverse; background-color: var(--tc-surface-2); border-color: var(--tc-border);">
            <div id="ai-debug-out" style="white-space: pre-wrap; font-family: monospace; font-size: 0.8rem; padding: 5px; color: var(--tc-fg);">@AiInteraction.GetContext()</div>
        </div>
    </div>

    <!-- AI Constraints Sidebar -->
    <div class="d-flex flex-column flex-grow-1" style="max-width: 500px;">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="form-label mb-0">AI Constraints</label>
            <button class="btn btn-outline-primary btn-sm"
                    onclick="window.copyToClipboard('ai-constraints-out', this)">
                Copy
            </button>
        </div>
        <div class="form-control" style="height: 385px; overflow-y: auto; background-color: var(--tc-surface-2); border-color: var(--tc-border);">
            <div id="ai-constraints-out" style="white-space: pre-wrap; font-family: monospace; font-size: 0.8rem; padding: 5px; color: var(--tc-fg);">@AiInteraction.GetConstraints()</div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TimeCalculatorProgramm TimeCalculator { get; set; } = default!;

    public AiInteraction AiInteraction { get; private set; } = default!;

    [Parameter] public EventCallback OnChanged { get; set; }

    protected override void OnInitialized()
    {
        AiInteraction = new AiInteraction(TimeCalculator);
        AiInteraction.OnContextUpdated += OnContextUpdated;

// TODO: Remove after debug finished
        AiInteraction.UserInput = "I worked for 4 hours 43 mins, then had 54 minutes lunch and after that worked till the end of my working day.";
    }

    private void OnContextUpdated(object? sender, List<FunctionCallResponse> e)
    {
        _ = NotifyChangedAsync();
    }

    private void AddTimeEntry()
    {
        TimeCalculator.AddTimeEntry();
        _ = NotifyChangedAsync();
    }

    private void SetRemainedTime()
    {
        TimeCalculator.SetRemainedTime();
        TimeCalculator.AddTimeEntry();
        _ = NotifyChangedAsync();
    }

    private Task NotifyChangedAsync()
    {
        return OnChanged.HasDelegate ? OnChanged.InvokeAsync() : Task.CompletedTask;
    }

    public bool IsTypeSelected(TimeType type)
    {
        return TimeCalculator.CurrentTimeEntry.Type == type;
    }

    private string GetTypeButtonClass(TimeType type)
    {
        return IsTypeSelected(type) ? "btn btn-primary" : "btn btn-outline-primary";
    }

}